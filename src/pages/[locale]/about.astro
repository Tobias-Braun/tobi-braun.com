---
import Base from '../../layouts/Base.astro'
import TimelineItem from '../../components/about/TimelineItem.vue'
import { getUi, type Locale } from '../../utils/locale'
import { experience } from '../../data/experience'

export async function getStaticPaths() {
  return [
    { params: { locale: 'de' } },
    { params: { locale: 'en' } },
  ]
}

const { locale } = Astro.params as { locale: Locale }
const ui = getUi(locale)
---

<Base title="CV – Tobias Braun">
  <div class="about" id="about-root">
    <section class="about-hero">
      <div class="about-hero__portrait">
        <img src="/intro-lifestyle.jpg" alt={ui.about.portraitAlt} />
      </div>
      <div class="about-hero__body">
        <h1 class="about-hero__title">{ui.about.heroTitle}</h1>
        <p>{ui.about.heroParagraph1}</p>
        <p>{ui.about.heroParagraph2}</p>
      </div>
    </section>

    <section class="timeline" id="contact">
      <h2 class="timeline__title gradient-text--green">{ui.about.timelineTitle}</h2>
      <ul class="timeline__list">
        {experience.map(entry => (
          <TimelineItem
            title={entry.title}
            period={entry.period}
            icon={entry.icon}
            description={entry.description}
            tags={entry.tags}
            active={entry.active}
          />
        ))}
      </ul>
    </section>
  </div>
</Base>

<script>
import { gsap } from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'

gsap.registerPlugin(ScrollTrigger)

gsap.from('.about-hero__portrait', {
  x: -80, scale: 0.95, opacity: 0, duration: 0.6, delay: 0.1, ease: 'power3.out',
})

gsap.from('.about-hero__title', { x: 60, opacity: 0, duration: 0.5, delay: 0.2, ease: 'power3.out' })

gsap.from('.about-hero__body p', {
  x: 60, opacity: 0, duration: 0.7, stagger: 0.15, delay: 0.35, ease: 'power2.out',
})

gsap.from('.timeline__title', {
  scrollTrigger: { trigger: '.timeline', start: 'top 80%' },
  y: -30, opacity: 0, duration: 0.6, ease: 'power3.out',
})

gsap.from('.item', {
  scrollTrigger: { trigger: '.timeline__list', start: 'top 80%' },
  x: -70, opacity: 0, duration: 0.8, stagger: 0.18, ease: 'power3.out',
})

gsap.from('.item__bullet', {
  scrollTrigger: { trigger: '.timeline__list', start: 'top 80%' },
  scale: 0, opacity: 0, duration: 0.5, stagger: 0.18, delay: 0.15, ease: 'back.out(2.5)',
})
</script>

<style lang="scss">
@use 'abstracts' as *;

.about {
  @include container;
  display: flex;
  flex-direction: column;
  gap: var(--space-2xl);
  padding-block: var(--space-xl);
}

.about-hero {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-xl);
  align-items: center;

  @include md {
    grid-template-columns: 1fr 2fr;
  }
}

.about-hero__portrait {
  aspect-ratio: 1;
  border-radius: var(--radius-2xl);
  overflow: hidden;
  border: 4px solid var(--surface-container);
  box-shadow: 0 12px 32px rgba(101, 47, 19, 0.1);

  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
}

.about-hero__body {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);

  p {
    @extend %body-lg;
    color: var(--on-surface-variant);
  }
}

.about-hero__title {
  @extend %headline-xl;
  color: var(--primary);
  margin-bottom: var(--space-sm);
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: var(--space-xl);
}

.timeline__title {
  @extend %headline-lg;
  color: var(--primary);
  align-self: flex-start;
  padding-bottom: var(--space-sm);
  border-bottom: 2px solid var(--surface-container-high);
}

.timeline__list {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: var(--space-xl);

  // Vertical timeline connector line
  &::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 24px;
    width: 2px;
    background: var(--surface-container-high);

    @include md {
      left: 40px;
    }
  }
}
</style>
