---
import AppHeader from '../components/layout/AppHeader.vue'
import AppFooter from '../components/layout/AppFooter.astro'
import { SimpleAnalytics } from 'astro-simpleanalytics-plugin'
import '../styles/main.scss'

interface Props { title: string }
const { title } = Astro.props
const locale = Astro.url.pathname.startsWith('/en') ? 'en' : 'de'
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&family=Be+Vietnam+Pro:wght@400;600&family=Allura&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />
  </head>
  <body>
    <AppHeader client:load locale={locale} />
    <main class="page">
      <slot />
    </main>
    <AppFooter />
    <SimpleAnalytics />
  </body>
</html>

<style>
body {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.page {
  flex: 1 1 auto;
  display: flex;
  flex-direction: column;
}
</style>
